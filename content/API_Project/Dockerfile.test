# ==========================================
# 文件名：content/API_Project/Dockerfile.test
# 用途：测试运行环境（国内源加速，内含 Pytest + JMeter）
# ==========================================
FROM python:3.12-slim

# 更换 Debian 源为阿里云镜像（兼容 Debian 12+ 的 deb822 格式）
RUN set -e && \
    if [ -f /etc/apt/sources.list.d/debian.sources ]; then \
        sed -i 's|http://deb.debian.org|http://mirrors.aliyun.com|g' /etc/apt/sources.list.d/debian.sources && \
        sed -i 's|http://security.debian.org|http://mirrors.aliyun.com|g' /etc/apt/sources.list.d/debian.sources; \
    elif [ -f /etc/apt/sources.list ]; then \
        sed -i 's|http://deb.debian.org|http://mirrors.aliyun.com|g' /etc/apt/sources.list && \
        sed -i 's|http://security.debian.org|http://mirrors.aliyun.com|g' /etc/apt/sources.list; \
    fi && \
    apt-get update

# 安装编译依赖 + JMeter 依赖（OpenJDK）
RUN apt-get install -y --no-install-recommends \
    gcc \
    libffi-dev \
    openjdk-21-jre-headless \
    wget \
    tzdata \
    && ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime \
    && echo "Asia/Shanghai" > /etc/timezone \
    && dpkg-reconfigure -f noninteractive tzdata 2>/dev/null || true \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 先复制依赖文件，利用 Docker 缓存层
COPY requirements.txt .

# 使用清华 PyPI 镜像安装 Python 依赖
RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
    -r requirements.txt

# ==========================================
# 安装 JMeter（清华镜像加速，版本 5.6.3）
# ==========================================
ENV JMETER_VERSION=5.6.3
RUN wget -q https://mirrors.tuna.tsinghua.edu.cn/apache/jmeter/binaries/apache-jmeter-${JMETER_VERSION}.tgz \
    && tar -xzf apache-jmeter-${JMETER_VERSION}.tgz -C /opt \
    && ln -s /opt/apache-jmeter-${JMETER_VERSION}/bin/jmeter /usr/local/bin/jmeter \
    && rm apache-jmeter-${JMETER_VERSION}.tgz \
    && jmeter --version | head -n 1

# ✅ 精简版 user.properties：只保留 Dashboard 报告必需的标准列
# 关键：绝对不能有 sample_count / error_count / encoding / hostname
# ✅ 修复 Dashboard 空白：恢复字符串时间戳，并同步报告生成器解析格式
RUN printf '%s\n' \
    'jmeter.save.saveservice.output_format=csv' \
    'jmeter.save.saveservice.time=true' \
    'jmeter.save.saveservice.timestamp_format=ms' \
    'jmeter.save.saveservice.label=true' \
    'jmeter.save.saveservice.response_code=true' \
    'jmeter.save.saveservice.response_message=true' \
    'jmeter.save.saveservice.thread_name=true' \
    'jmeter.save.saveservice.data_type=true' \
    'jmeter.save.saveservice.successful=true' \
    'jmeter.save.saveservice.bytes=true' \
    'jmeter.save.saveservice.sent_bytes=true' \
    'jmeter.save.saveservice.latency=true' \
    'jmeter.save.saveservice.connect_time=true' \
    'jmeter.save.saveservice.idle_time=true' \
    'jmeter.save.saveservice.url=true' \
    > /opt/apache-jmeter-${JMETER_VERSION}/bin/user.properties

# ✅ 关键：同步 Dashboard 报告生成器的解析格式（否则仍空白）
RUN echo 'jmeter.reportgenerator.date_format=yyyy/MM/dd HH:mm:ss.SSS' \
    >> /opt/apache-jmeter-${JMETER_VERSION}/bin/reportgenerator.properties

# 复制项目源码
COPY . .

# 创建报告目录
RUN mkdir -p /app/report/allure-results /app/report/jmeter-report

# 默认入口
CMD ["pytest", "--version"]